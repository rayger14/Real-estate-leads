# Core LLM (required for hosted chat responses)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_DAILY_CALL_LIMIT=40

# Internal dashboard auth
INTERNAL_DASHBOARD_PASSWORD=14

# Real-time macro market data from FRED (optional but recommended)
FRED_API_KEY=

# Property AVM / rent estimate enrichment (optional)
RENTCAST_API_KEY=

# Property/deed sale snapshots (optional, paid enterprise)
ATTOM_API_KEY=

# Optional obituary feed URLs (comma-separated RSS/Atom feeds)
OBITUARY_FEEDS=

# Optional remote probate CSV source for nightly ingest
PROBATE_CSV_URL=

# Secret for cron-triggered ingest endpoint (/api/jobs/nightly-ingest)
CRON_SECRET=

# Optional: telemetry/budget tracking provider key
# HELICONE_API_KEY=
